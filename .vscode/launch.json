    "version": "0.2.0",
    "configurations": [

        {
            "type": "stlinkgdbtarget",
            "request": "launch",
            "name": "STM32Cube: Launch ST-Link GDB Server",
            "origin": "snippet",
            "cwd": "${workspaceFolder}",
            "runEntry": "main",
            "imagesAndSymbols": [
                {
                    "imageFileName": "${workspaceFolder}/build/Debug/OUTPUT.elf"
                }
            ],
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": "4"
            }
        }
    ]
}